# Secrets
.env

# ADK local runtime state (session DB created by `adk web`)
.adk/

# Generated outputs (keep placeholder so directory exists in git)
outputs/*
!outputs/.gitkeep
db/*
!db/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Audio / recordings
*.mp3
*.wav
recordings/*
!recordings/.gitkeep

# Notebooks checkpoints
.ipynb_checkpoints/

# macOS
.DS_Store
